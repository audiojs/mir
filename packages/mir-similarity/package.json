  },
  "audio": "./audio.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audiojs/mir.git",
    "directory": "packages/mir-similarity"
  },
  "funding": "https://github.com/sponsors/audiojs",
  "types": "index.d.ts"
}
