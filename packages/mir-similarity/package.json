{
  "name": "@audio/mir-similarity",
  "version": "1.1.4",
  "description": "Audio similarity — distance metric between recordings",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "audio",
    "dsp",
    "mir",
    "similarity"
  ],
  "license": "MIT",
  "author": "Dmitry Iv. <dfcreative@gmail.com>",
  "engines": {
    "node": ">=18"
  },
  "main": "similarity.js",
  "exports": {
    ".": "./similarity.js",
    "./audio": {
      "types": "./audio.d.ts",
      "default": "./audio.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "similarity.js",
    "audio.js",
    "audio.d.ts",
    "index.d.ts"
  ],
  "dependencies": {
    "@audio/spectral-mfcc": "^1.0.0",
    "@audio/mir-chroma": "^1.0.0"
  },
  "publishConfig": {
