{
  "name": "@audio/mir-fingerprint",
  "version": "1.1.3",
  "description": "Landmark fingerprinting — spectral peak constellation hashes + offset-vote matching (Wang 2003 class)",
  "type": "module",
  "sideEffects": false,
  "main": "fingerprint.js",
  "exports": {
    ".": "./fingerprint.js",
    "./audio": {
      "types": "./audio.d.ts",
      "default": "./audio.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "fingerprint.js",
    "audio.js",
    "audio.d.ts",
    "index.d.ts"
  ],
  "dependencies": {
    "fourier-transform": "^2.2.0"
  },
  "keywords": [
    "audio",
    "dsp",
    "mir",
    "fingerprint",
    "shazam",
    "landmark"
  ],
  "license": "MIT",
  "author": "Dmitry Iv. <dfcreative@gmail.com>",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "audio": "./audio.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audiojs/mir.git",
    "directory": "packages/mir-fingerprint"
  },
  "funding": "https://github.com/sponsors/audiojs",
  "types": "index.d.ts"
}
